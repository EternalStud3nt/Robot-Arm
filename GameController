import pygame
import time

class GameController:
    def __init__(self):
        pygame.init()
        pygame.joystick.init()
        self.joystick = pygame.joystick.Joystick(0)
        self.joystick.init()

        # Initialize joystick axes
        self.left_joystick_horizontal_axis = 0
        self.left_joystick_vertical_axis = 0
        self.right_joystick_horizontal_axis = 0
        self.right_joystick_vertical_axis = 0

        # Initialize buttons
        self.x_button = 0
        self.square_button = 0
        self.circle_button = 0
        self.triangle_button = 0
        self.l1_button = 0
        self.l2_button = 0
        self.r1_button = 0
        self.r2_button = 0

        # Initialize arrow keys
        self.arrow_horizontal_axis = 0
        self.arrow_vertical_axis = 0

    def update(self):
        pygame.event.pump()

        # Update joystick values
        self.left_joystick_horizontal_axis = self.joystick.get_axis(0)
        self.left_joystick_vertical_axis = self.joystick.get_axis(1)
        self.right_joystick_horizontal_axis = self.joystick.get_axis(2)
        self.right_joystick_vertical_axis = self.joystick.get_axis(3)

        # Update button values
        self.x_button = self.joystick.get_button(0)
        self.circle_button = self.joystick.get_button(1)
        self.square_button = self.joystick.get_button(2)
        self.triangle_button = self.joystick.get_button(3)
        self.l1_button = self.joystick.get_button(4)
        self.r1_button = self.joystick.get_button(5)


        # Update arrow keys values
        self.arrow_horizontal_axis = self.joystick.get_hat(0)[0]
        self.arrow_vertical_axis = self.joystick.get_hat(0)[1]

    def print_values(self):
        print("Left Joystick Horizontal Axis:", self.left_joystick_horizontal_axis)
        print("Left Joystick Vertical Axis:", self.left_joystick_vertical_axis)
        print("Right Joystick Horizontal Axis:", self.right_joystick_horizontal_axis)
        print("Right Joystick Vertical Axis:", self.right_joystick_vertical_axis)
        print("X Button:", self.x_button)
        print("Square Button:", self.square_button)
        print("Circle Button:", self.circle_button)
        print("Triangle Button:", self.triangle_button)
        print("L1 Button:", self.l1_button)
        print("R1 Button:", self.r1_button)
        print("Arrow Horizontal Axis:", self.arrow_horizontal_axis)
        print("Arrow Vertical Axis:", self.arrow_vertical_axis)

if __name__ == "__main__":
    controller = GameController()
    while True:
        time.sleep(2)
        controller.update()
        controller.print_values()
